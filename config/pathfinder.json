{
  "llm": {
    "adapter": "ollama",
    "base_url": "http://localhost:11434",
    "model": "qwen2.5:3b",
    "temperature": 0.1,
    "max_tokens": 2048,
    "context_window": 4096,
    "timeout_ms": 60000
  },
  "mcp_servers": [
    {
      "id": "filesystem",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "."],
      "enabled": true
    }
  ],
  "agent": {
    "watched_folders": [],
    "poll_interval_ms": 5000,
    "max_file_size_mb": 50,
    "supported_extensions": [".docx", ".pdf", ".txt", ".doc"]
  },
  "memory": {
    "db_path": "pathfinder_memory.db",
    "fact_ttl_days": 90,
    "enable_versioning": true
  }
}
