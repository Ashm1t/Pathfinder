{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pathfinder HUD",
  "version": "0.1.0",
  "identifier": "in.pathfinder.hud",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "hud",
        "title": "Pathfinder HUD",
        "width": 1920,
        "height": 1080,
        "x": 0,
        "y": 0,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": ["icons/icon.ico"]
  }
}
