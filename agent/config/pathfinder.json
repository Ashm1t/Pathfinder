{
  "llm": {
    "adapter": "ollama",
    "base_url": "http://localhost:11434",
    "model": "qwen2.5:3b",
    "temperature": 0.1,
    "max_tokens": 2048,
    "context_window": 4096,
    "timeout_s": 60
  },
  "agent": {
    "watched_folders": [
      "sample_data"
    ],
    "poll_interval_s": 5.0,
    "max_file_size_mb": 50,
    "supported_extensions": [".txt", ".md", ".docx", ".pdf"]
  },
  "memory": {
    "db_path": "pathfinder_memory.db",
    "fact_ttl_days": 90
  },
  "ipc": {
    "host": "127.0.0.1",
    "port": 8765
  }
}
